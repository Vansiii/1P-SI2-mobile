# Environment Configuration Example
# Copia este archivo como .env.development o .env.production y configura los valores

# Environment name (development, staging, production)
ENVIRONMENT=development

# API Base URL
# API_BASE_URL is the generic fallback.
# For mobile development you can define device-specific URLs:
# - Android emulator: API_BASE_URL_ANDROID_EMULATOR=http://10.0.2.2:8000
# - Android physical device: API_BASE_URL_ANDROID_DEVICE=http://192.168.1.50:8000
# - iOS simulator: API_BASE_URL_IOS_SIMULATOR=http://localhost:8000
# - iOS physical device: API_BASE_URL_IOS_DEVICE=http://192.168.1.50:8000
API_BASE_URL=http://localhost:8000
API_BASE_URL_ANDROID_EMULATOR=http://10.0.2.2:8000
API_BASE_URL_ANDROID_DEVICE=http://192.168.1.50:8000
API_BASE_URL_IOS_SIMULATOR=http://localhost:8000
API_BASE_URL_IOS_DEVICE=http://192.168.1.50:8000

# Features
ENABLE_LOGGING=true
ENABLE_DEBUG_BANNER=true

# Timeouts (en segundos)
CONNECT_TIMEOUT=120
RECEIVE_TIMEOUT=120
