# Environment Configuration Example
# Copia este archivo a .env.development o .env.production y configura tus valores

# Environment name
ENVIRONMENT=development

# API Base URL
API_BASE_URL=http://localhost:8000

# Features
ENABLE_LOGGING=true
ENABLE_DEBUG_BANNER=true

# Timeouts (en segundos)
CONNECT_TIMEOUT=60
RECEIVE_TIMEOUT=60
