# Environment Configuration Example
# Copia este archivo como .env.development o .env.production y configura los valores

# Environment name (development, staging, production)
ENVIRONMENT=development

# API Base URL
# Development (local): http://localhost:8000 o http://TU_IP:8000
# Production: https://tu-backend.railway.app
API_BASE_URL=http://localhost:8000

# Features
ENABLE_LOGGING=true
ENABLE_DEBUG_BANNER=true

# Timeouts (en segundos)
CONNECT_TIMEOUT=120
RECEIVE_TIMEOUT=120
