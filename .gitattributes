# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# iOS specific
*.pbxproj text eol=lf
*.plist text eol=lf
*.xcconfig text eol=lf
*.storyboard text eol=lf

# Android specific
*.pro text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.apk binary
*.aab binary
*.ipa binary
*.so binary
*.dylib binary
*.dll binary
*.exe binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Exclude files from export (git archive)
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
build/ export-ignore
.dart_tool/ export-ignore
.flutter-plugins export-ignore
.flutter-plugins-dependencies export-ignore
